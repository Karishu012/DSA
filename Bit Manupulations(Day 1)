3.Reverse the Bits of a Given 32-bit Unsigned Integer
import java.util.*;

class Main
{
    public static void main(String[] args)
    {
        Scanner sc = new Scanner(System.in);

        int n = sc.nextInt();

        int result = 0;

        for(int i = 0; i < 32; i++)
        {
            result <<= 1;          // Make space

            result |= (n & 1);     // Copy last bit

            n >>= 1; //or n>>>=1   // Move to next bit
        }

        System.out.println(result);
    }
}
