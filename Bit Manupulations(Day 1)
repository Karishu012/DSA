5.Swap all odd-position bits and even-position bits of a 32-bit integer using Bit Manipulation
import java.util.*;

class Main
{
    public static void main(String[] args)
    {
        Scanner sc = new Scanner(System.in);

        int n = sc.nextInt();

        int evenBits = n & 0x55555555;
        int oddBits = n & 0xAAAAAAAA;

        evenBits <<= 1;
        oddBits >>= 1;

        int result = evenBits | oddBits;

        System.out.println(result);
    }
}

