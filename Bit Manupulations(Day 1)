2.Find the number of bits that must be flipped to convert A int B
import java.util.*;
class Main {
    public static void main(String[] args) {
       Scanner sc=new Scanner(System.in);
       int a=sc.nextInt();
       int b=sc.nextInt();
       int xor=a^b;
       int count=0;
       while(xor>0)
       {
           count+=xor%2;
           xor/=2;
       }
       System.out.println(count);
    }
}
