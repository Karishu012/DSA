4.Find missing number in an array using xor 
import java.util.*;
class Main {
    public static int findmissing(int n,int[] arr){
        int xor1=0,xor2=0;
        for(int i=0;i<=n;i++)
        {
            xor1^=i;
        }
        for(int num:arr)
        {
            xor2^=num;
        }
       return xor1^xor2;
    }
    public static void main(String[] args) {
       Scanner sc=new Scanner(System.in);
        int n=sc.nextInt();
        int[] a=new int[n];
        for(int i=0;i<n-1;i++)
        {
            a[i]=sc.nextInt();
        }
        System.out.println(findmissing(n,a));
    }
}
