5.Find all numbers in range [L, R] that are both Perfect Squares and Perfect Numbers
import java.util.Scanner;
public class Main {
    public static boolean isPerfectSquare(int n) {
        int root = (int) Math.sqrt(n);
        return root * root == n;
    }
    public static boolean isPerfectNumber(int n) {
        if (n <= 1)
            return false;
        int sum = 1;
        for (int i = 2; i * i <= n; i++) {
            if (n % i == 0) {
                sum += i;
                if (i != n / i) {
                    sum += n / i;
                }
            }
        }
------------------------------------------------------------------------------------
        return sum == n;
    }

    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        int L = sc.nextInt();
        int R = sc.nextInt();

        boolean found = false;

        for (int i = L; i <= R; i++) {
            if (isPerfectSquare(i) && isPerfectNumber(i)) {
                System.out.print(i + " ");
                found = true;
            }
        }

        if (!found) {
            System.out.println("No such number found");
        }

        sc.close();
    }
}
