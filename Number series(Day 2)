3.Nelson number(111) :check if n is 111 or a multiple pattern. Generate:find all repunit numbers up to n 
import java.util.*;
class Main {
    // Check if a number contains only digit 1
    public static boolean isNelson(int n) {
        if (n <= 0) return false;
        while (n > 0) {
            if (n % 10 != 1) {
                return false;
            }
            n /= 10;
        }
        return true;
    }
    // Print all repunit numbers up to n
    public static void printRepunits(int n) {
        int repunit = 1;
        while (repunit <= n) {
            System.out.println(repunit + " ");
            repunit = repunit * 10 + 1;
        }
        System.out.println();
    }
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        int n = sc.nextInt();
        if (isNelson(n))
            System.out.println(n + " is a Nelson Number");
        else
            System.out.println(n + " is not a Nelson Number");
        System.out.println("Repunit numbers up to " + n + ":");
        printRepunits(n);
    }
}
