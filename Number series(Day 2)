2.unique number no digits repeated print all unique 3 digit numbers (100-999)
import java.util.*;
class Main {
    public static void main(String[] args) {
        for (int n = 100; n <= 999; n++) {
            int a = n / 100;        // hundreds digit
            int b = (n / 10) % 10;  // tens digit
            int c = n % 10;         // units digit
            if (a != b && b != c && a != c) {
                System.out.print(n + " ");
            }
        }
    }
}
