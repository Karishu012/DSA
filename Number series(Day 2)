1.Pronic Number
Explanation
Product of two consecutive integers.
import java.util.Scanner;
public class PronicNumber {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        int n = sc.nextInt();
        boolean flag = false;
        for (int i = 0; i <= n; i++) {
            if (i * (i + 1) == n) {
                flag = true;
                break;
            }
        }
        System.out.println(flag ? "Pronic Number" : "Not Pronic Number");
    }
}
