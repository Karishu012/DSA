5.print a 90 degree clockwise rotated right angle triangle of ascending numbers
import java.util.*;
class Main {
    public static void main(String[] args) {
        Scanner sc=new Scanner(System.in);
        int n=sc.nextInt();
       for(int i=n;i>=1;i--)
       {
           for(int j=0;j<n-i;j++)
           {
               System.out.print("  ");
           }
           for(int j=1;j<=i;j++)
           {
               System.out.print(j+" ");
           }
           System.out.println();
       }
    }
}
