1.Print a Hallow Diamond of stars
Hallow diamond pattern
class Solution {
    void printPat(int n) {
        // Upper half
        for (int i = 1; i <= n; i++) {
            System.out.print(" ");
            for (int j = 1; j <= n - i; j++) {
                System.out.print("  ");
            }
            System.out.print("*");
            if (i > 1) {
                for (int j = 1; j <= 4 * i - 5; j++) {
                    System.out.print(" ");
                }
                System.out.print("*");
            }
            System.out.println();
        }
        // Lower half
        for (int i = n - 1; i >= 1; i--) {
            System.out.print(" ");
            for (int j = 1; j <= n - i; j++) {
                System.out.print("  ");
            }
            System.out.print("*");
            if (i > 1) {
                for (int j = 1; j <= 4 * i - 5; j++) {
                    System.out.print(" ");
                }
                System.out.print("*");
            }
            System.out.println();
        }
    }
}
