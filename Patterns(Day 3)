-----------------------(or)--------------------------------------
class Solution {
    void printPat(int n) {
        int totalRows = 2 * n - 1;
        for (int i = 1; i <= totalRows; i++) {
            int spaces = Math.abs(n - i);
            System.out.print(" "); 
            System.out.print("  ".repeat(spaces));
            int level = n - spaces;
            if (level == 1) {
                System.out.println("*");
            } else {
                int innerSpaces = 4 * level - 5;
                System.out.print("*");
                System.out.print(" ".repeat(innerSpaces));
                System.out.println("*");
            }
        }
    }
}
